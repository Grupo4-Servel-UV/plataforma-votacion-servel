{
    "name": "plataforma-votacion-servel",
    "private": true,
    "version": "0.0.1",
    "scripts": {
        "start:api:dev": "pnpm --filter api dev",
        "start:web:dev": "pnpm --filter web dev -p 3001",
        "dev": "concurrently -c \"cyan,magenta\" -n \"API,WEB\" \"pnpm run start:api:dev\" \"pnpm run start:web:dev\"",
        "build:api": "pnpm --filter api build",
        "build:web": "pnpm --filter web build",
        "prepare": "husky",
        "lint": "pnpm -r run lint",
        "lint:fix": "pnpm -r run lint --fix",
        "format": "prettier --write \"{apps,libs}/**/*.{ts,tsx}\""
    },
    "devDependencies": {
        "@commitlint/cli": "^20.5.0",
        "@commitlint/config-conventional": "^20.5.0",
        "@nestjs/cli": "^10.4.8",
        "@nestjs/schematics": "^10.2.3",
        "@nestjs/testing": "^10.4.15",
        "@types/node": "^20.19.39",
        "@typescript-eslint/eslint-plugin": "^8.58.2",
        "@typescript-eslint/parser": "^8.58.2",
        "concurrently": "^9.2.1",
        "eslint": "^10.2.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "prettier": "^3.8.3",
        "ts-loader": "^9.5.7",
        "ts-node": "^10.9.2",
        "typescript": "^5.6.3"
    },
    "lint-staged": {
        "*.{ts,tsx,js}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,md,yml}": [
            "prettier --write"
        ]
    }
}